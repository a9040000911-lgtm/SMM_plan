model CmsPage {
  id        String      @id @default(uuid())
  projectId String
  slug      String
  title     String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blocks    CmsBlock[]
  strings   CmsString[]

  @@unique([projectId, slug])
  @@map("CmsPage")
}

model CmsBlock {
  id          String   @id @default(uuid())
  pageId      String
  type        String // HERO, FEATURES, REVIEWS, etc.
  slot        String? // HERO_ZONE, BOTTOM_ZONE, etc.
  content     Json // Widget content
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  page        CmsPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, order])
  @@map("CmsBlock")
}

model CmsString {
  id          String   @id @default(uuid())
  projectId   String
  pageId      String? // Optional for global strings
  key         String
  value       String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  page        CmsPage? @relation(fields: [pageId], references: [id])

  @@unique([projectId, key, pageId]) // Note: NULL pageId means global string. PG allows multiple NULLs, so app-level uniqueness is required for globals.
  @@index([projectId, key])
  @@map("CmsString")
}

model MediaAsset {
  id        String   @id @default(uuid())
  projectId String
  url       String
  type      String   @default("IMAGE") // IMAGE, VIDEO
  altText   String?
  fileSize  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("MediaAsset")
}

enum OrgLedgerType {
  TOPUP
  REFUND
  SERVICE_COST
  ADJUSTMENT
}

model Organization {
  id              String                    @id @default(uuid())
  name            String
  ownerId         String
  masterBalance   Decimal                   @default(0.00) @db.Decimal(20, 2)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  owner           User                      @relation("OrganizationOwner", fields: [ownerId], references: [id])
  projects        Project[]
  ledgerEntries   OrganizationLedgerEntry[]
  customB2BMarkup Decimal?                  @db.Decimal(10, 2)

  @@map("Organization")
}

model OrganizationLedgerEntry {
  id             String        @id @default(uuid())
  organizationId String
  amount         Decimal       @db.Decimal(20, 2)
  currency       Currency      @default(RUB)
  balanceBefore  Decimal       @db.Decimal(20, 2)
  balanceAfter   Decimal       @db.Decimal(20, 2)
  type           OrgLedgerType
  referenceId    String?
  description    String?
  createdAt      DateTime      @default(now())
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
  @@map("OrganizationLedgerEntry")
}

model Subscription {
  id               String   @id @default(uuid())
  userId           String   @unique
  projectId        String?
  status           String   @default("ACTIVE") // ACTIVE, CANCELED, PAST_DUE
  currentPeriodEnd DateTime
  autoRenew        Boolean  @default(true)
  paymentMethodId  String? // Сохраненный токен от YooKassa
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("Subscription")
}
