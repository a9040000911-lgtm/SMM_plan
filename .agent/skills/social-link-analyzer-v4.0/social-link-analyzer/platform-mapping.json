{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "4.0.0",
  "updated": "2026-03-27",
  "changes": [
    "Исправлены критические ошибки regex",
    "Добавлен флаг ambiguous для неоднозначных форматов",
    "Добавлены азиатские платформы: Douyin, Weibo, Bilibili, Kuaishou, Xiaohongshu",
    "Исправлен Instagram highlights regex",
    "Добавлен $ в конец Spotify URI regex"
  ],
  "platforms": {
    "vk": {
      "name": "ВКонтакте",
      "name_en": "VK",
      "category": "social_network",
      "country": "RU",
      "domains": [
        "vk.com",
        "m.vk.com",
        "vk.me",
        "vk.cc",
        "live.vkvideo.ru"
      ],
      "primary_domain": "vk.com",
      "url_patterns": {
        "profile_id": {
          "pattern": "/id{user_id}",
          "regex": "^https?://(?:m\\.)?vk\\.com/id(\\d+)$",
          "example": "https://vk.com/id1",
          "ambiguous": false
        },
        "group_id": {
          "pattern": "/(club|public|event){group_id}",
          "regex": "^https?://(?:m\\.)?vk\\.com/(club|public|event)(\\d+)$",
          "example": "https://vk.com/club22884714",
          "ambiguous": false,
          "groups": ["type", "group_id"]
        },
        "screen_name": {
          "pattern": "/{screen_name}",
          "regex": "^https?://(?:m\\.)?vk\\.com/([a-zA-Z][a-zA-Z0-9_.]{1,31})$",
          "example": "https://vk.com/durov",
          "ambiguous": true,
          "ambiguity_type": "vk_screen_name",
          "ambiguity_options": ["profile", "group"],
          "note": "Может быть профилем или группой. Используйте /id или /club для однозначности"
        },
        "wall_post": {
          "pattern": "/wall{owner_id}_{post_id}",
          "regex": "^https?://(?:m\\.)?vk\\.com/wall(-?\\d+)_(\\d+)$",
          "example": "https://vk.com/wall-22884714_12345",
          "ambiguous": false
        },
        "photo": {
          "pattern": "/photo{owner_id}_{photo_id}",
          "regex": "^https?://(?:m\\.)?vk\\.com/photo(-?\\d+)_(\\d+)$",
          "example": "https://vk.com/photo-22884714_457654321",
          "ambiguous": false
        },
        "video": {
          "pattern": "/video{owner_id}_{video_id}",
          "regex": "^https?://(?:m\\.)?vk\\.com/video(-?\\d+)_(\\d+)$",
          "example": "https://vk.com/video-22884714_456239687",
          "ambiguous": false
        },
        "clip": {
          "pattern": "/clip{owner_id}_{clip_id}",
          "regex": "^https?://(?:m\\.)?vk\\.com/clip(-?\\d+)_(\\d+)$",
          "example": "https://vk.com/clip-22884714_456239487",
          "ambiguous": false
        },
        "comment": {
          "pattern": "/wall{owner_id}_{post_id}?reply={comment_id}",
          "regex": "^https?://(?:m\\.)?vk\\.com/wall(-?\\d+)_(\\d+)\\?reply=(\\d+)",
          "example": "https://vk.com/wall-22884714_12345?reply=67890",
          "ambiguous": false
        },
        "article": {
          "pattern": "/@{screen_name}/{slug}",
          "regex": "^https?://(?:m\\.)?vk\\.com/@([a-zA-Z0-9_]+)/([^/]+)",
          "example": "https://vk.com/@aprilclub/kak-rabotat",
          "ambiguous": false
        }
      },
      "smm_services": {
        "profile": ["followers", "friends"],
        "group": ["members"],
        "wall_post": ["likes", "comments", "reposts"],
        "video": ["views", "likes"],
        "clip": ["views", "likes"],
        "photo": ["likes", "comments"]
      }
    },
    "youtube": {
      "name": "YouTube",
      "name_en": "YouTube",
      "category": "video_platform",
      "country": "US",
      "domains": [
        "youtube.com",
        "www.youtube.com",
        "m.youtube.com",
        "youtu.be",
        "youtube-nocookie.com"
      ],
      "primary_domain": "youtube.com",
      "url_patterns": {
        "video": {
          "pattern": "/watch?v={video_id}",
          "regex": "^https?://(?:www\\.)?youtube\\.com/watch\\?v=([a-zA-Z0-9_-]{11})$",
          "example": "https://youtube.com/watch?v=dQw4w9WgXcQ",
          "ambiguous": false
        },
        "video_short": {
          "pattern": "youtu.be/{video_id}",
          "regex": "^https?://youtu\\.be/([a-zA-Z0-9_-]{11})$",
          "example": "https://youtu.be/dQw4w9WgXcQ",
          "ambiguous": false
        },
        "shorts": {
          "pattern": "/shorts/{video_id}",
          "regex": "^https?://(?:www\\.)?youtube\\.com/shorts/([a-zA-Z0-9_-]{11})$",
          "example": "https://youtube.com/shorts/dQw4w9WgXcQ",
          "ambiguous": false
        },
        "live": {
          "pattern": "/live/{video_id}",
          "regex": "^https?://(?:www\\.)?youtube\\.com/live/([a-zA-Z0-9_-]{11})$",
          "example": "https://youtube.com/live/dQw4w9WgXcQ",
          "ambiguous": false
        },
        "channel_handle": {
          "pattern": "/@{handle}",
          "regex": "^https?://(?:www\\.)?youtube\\.com/@([a-zA-Z0-9_.-]+)$",
          "example": "https://youtube.com/@MrBeast",
          "ambiguous": false
        },
        "channel_id": {
          "pattern": "/channel/{channel_id}",
          "regex": "^https?://(?:www\\.)?youtube\\.com/channel/(UC[a-zA-Z0-9_-]{22})$",
          "example": "https://youtube.com/channel/UCX6OQ3DkA2zQ5j3z5xZ5c6A",
          "ambiguous": false
        },
        "playlist": {
          "pattern": "/playlist?list={playlist_id}",
          "regex": "^https?://(?:www\\.)?youtube\\.com/playlist\\?list=([a-zA-Z0-9_-]+)$",
          "example": "https://youtube.com/playlist?list=PLrAXtmRdnEQy4Q",
          "ambiguous": false
        }
      },
      "smm_services": {
        "channel": ["subscribers"],
        "video": ["views", "likes", "comments"],
        "shorts": ["views", "likes"],
        "live": ["viewers"]
      }
    },
