  "normalization_rules": [
    {
      "from": "^https?://m\\.",
      "to": "https://",
      "description": "Удаление мобильного префикса"
    },
    {
      "from": "^https?://www\\.",
      "to": "https://",
      "description": "Удаление www префикса"
    },
    {
      "from": "/$",
      "to": "",
      "description": "Удаление trailing slash"
