
# =============================================================================
# SMMPlan — Продакшн конфигурация (.env)
# =============================================================================
# Скопируйте этот файл: cp .env.example .env
# Затем заполните СВОИ значения ниже.
# ВАЖНО: Вам НЕ нужно менять DATABASE_URL и REDIS_URL — они переопределяются
# в docker-compose.prod.yml автоматически для внутренней сети Docker.

# --- БАЗА ДАННЫХ (PostgreSQL) ---
# Этот URL используется ТОЛЬКО при локальной разработке без Docker.
# Docker Compose переопределит его на: postgresql://smmuser:smmpassword@db:5432/smmplan
DATABASE_URL="postgresql://smmuser:smmpassword@localhost:5432/smmplan?schema=public"

# --- REDIS ---
# Docker Compose переопределит на: redis://redis:6379
REDIS_URL="redis://localhost:6379"

# --- TELEGRAM БОТ ---
TELEGRAM_BOT_TOKEN="ВСТАВЬТЕ_ТОКЕН_БОТА"
BOT_USERNAME="имя_бота_без_собаки"
ADMIN_TG_ID="ваш_telegram_id"

# --- ВЕБ-ПРИЛОЖЕНИЕ ---
# Укажите ваш домен (или IP сервера с портом)
NEXT_PUBLIC_URL="https://ваш-домен.ru"
WEBAPP_URL="https://ваш-домен.ru"
NEXT_PUBLIC_APP_URL="https://ваш-домен.ru"

# --- ОПЛАТА (YooKassa) ---
YOOKASSA_SHOP_ID="ваш_shop_id"
YOOKASSA_SECRET_KEY="ваш_секретный_ключ"

# --- ПОЧТА (SMTP) ---
SMTP_HOST="smtp.yandex.ru"
SMTP_PORT=465
SMTP_USER="your@email.ru"
SMTP_PASSWORD="app_password"

# --- БЕЗОПАСНОСТЬ ---
# Генерация: openssl rand -base64 32
NEXTAUTH_SECRET="СГЕНЕРИРУЙТЕ_СВОЙ_СЕКРЕТ"
NEXTAUTH_URL="https://ваш-домен.ru"

# Master-ключ для 2FA входа в админку
ADMIN_MASTER_KEY="ИЗМЕНИТЕ_НА_СВОЙ"

# --- ПРОВАЙДЕРЫ (API ключи) ---
VEXBOOST_API_KEY=""
GEMINI_API_KEY=""

# --- СИСТЕМНЫЕ ---
NODE_ENV="production"
PORT=3000
